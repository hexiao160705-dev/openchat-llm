# OpenAI-compatible API key.
# Leave empty until you configure your own deployment.
OPENAI_API_KEY=

# Optional OpenAI-compatible API base URL.
# Example: https://api.openai.com
BASE_URL=

# Optional access password, separated by commas.
CODE=

# Optional model controls.
# Example: -all,+gpt-4o-mini,+deepseek-chat
CUSTOM_MODELS=

# Optional default model.
DEFAULT_MODEL=

# Keep user-provided API key configuration available by default.
HIDE_USER_API_KEY=0

# Enable only when your endpoint supports balance query.
ENABLE_BALANCE_QUERY=0

# Optional feature flags.
ENABLE_MCP=
DISABLE_FAST_LINK=

